# ═══════════════════════════════════════════════════════════════════
# Sincronia — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL 14)
# ═══════════════════════════════════════════════════════════════════
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sincronia_dev_password_2026
POSTGRES_DB=sincronia_development
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://postgres:sincronia_dev_password_2026@localhost:5432/sincronia_development

# ═══════════════════════════════════════════════════════════════════
# REDIS (Redis 7-alpine)
# ═══════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════
# RAILS
# ═══════════════════════════════════════════════════════════════════
RAILS_ENV=development
RAILS_MASTER_KEY=
SECRET_KEY_BASE=
RAILS_LOG_TO_STDOUT=true
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# ═══════════════════════════════════════════════════════════════════
# JWT Authentication
# ═══════════════════════════════════════════════════════════════════
JWT_SECRET=sincronia_jwt_secret_key_change_in_production
JWT_EXPIRATION=7d

# ═══════════════════════════════════════════════════════════════════
# FRONTEND (Vite)
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001/cable

# ═══════════════════════════════════════════════════════════════════
# STORAGE (DigitalOcean Spaces / S3-compatible)
# ═══════════════════════════════════════════════════════════════════
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_REGION=nyc3
SPACES_BUCKET=sincronia-uploads
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=${SPACES_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${SPACES_SECRET_ACCESS_KEY}

# ═══════════════════════════════════════════════════════════════════
# AUTENTICAÇÃO SOCIAL
# ═══════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════
# PAGAMENTOS
# ═══════════════════════════════════════════════════════════════════
# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# MercadoPago (PIX)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_CLIENT_ID=

# ═══════════════════════════════════════════════════════════════════
# ANALYTICS
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# PostHog (Vite/Frontend)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ═══════════════════════════════════════════════════════════════════
# MONITORAMENTO (Sentry)
# ═══════════════════════════════════════════════════════════════════
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=main
SCOUT_KEY=

# Sentry (Vite/Frontend)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=main

# ═══════════════════════════════════════════════════════════════════
# NOTIFICAÇÕES
# ═══════════════════════════════════════════════════════════════════
SLACK_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════════
# EMAIL (SMTP)
# ═══════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sincronia.app

# ═══════════════════════════════════════════════════════════════════
# OPENAI (AI Concierge)
# ═══════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# ═══════════════════════════════════════════════════════════════════
# ACTIVE ADMIN
# ═══════════════════════════════════════════════════════════════════
ADMIN_EMAIL=admin@sincronia.app
ADMIN_PASSWORD=Admin123!

# ═══════════════════════════════════════════════════════════════════
# SIDEKIQ
# ═══════════════════════════════════════════════════════════════════
SIDEKIQ_CONCURRENCY=5
SIDEKIQ_TIMEOUT=30

# ═══════════════════════════════════════════════════════════════════
# CORS (Cross-Origin Resource Sharing)
# ═══════════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ═══════════════════════════════════════════════════════════════════
# PRODUÇÃO
# ═══════════════════════════════════════════════════════════════════
APP_HOST=sincronia.app
FORCE_SSL=true
CORS_PRODUCTION_ORIGINS=https://sincronia.app,https://www.sincronia.app
